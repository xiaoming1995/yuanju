# Docker Compose 专用环境变量
# 用于 `docker compose up -d --build`
# 使用方式：
#   cp backend/.env.docker.example backend/.env.docker
#   然后填入真实密码与密钥
# 注意：
# - DATABASE_URL 中的 host 必须是 `postgres`
# - REDIS_URL 中的 host 必须是 `redis`
# - POSTGRES_PASSWORD 必须与 DATABASE_URL 中的密码一致

PORT=9002
DATABASE_URL=postgres://yuanju:change-me-strong-password@postgres:5432/yuanju?sslmode=disable
POSTGRES_PASSWORD=change-me-strong-password
REDIS_URL=redis://redis:6379
JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_JWT_SECRET=change-me-use-openssl-rand-hex-32
ADMIN_ENCRYPTION_KEY=change-me-exactly-32-bytes-long!
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
OPENAI_API_KEY=
FRONTEND_URL=http://localhost:3000
