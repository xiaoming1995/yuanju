# ============================
# 缘聚 后端环境变量配置
# ============================
# 使用方式：cp .env.example .env && nano .env

# 本地 `go run ./cmd/api` 端口
PORT=9002

# 本地开发数据库连接（直接连宿主机）
DATABASE_URL=postgres://yuanju:your-strong-password@localhost:5432/yuanju?sslmode=disable

# 本地开发 Redis
REDIS_URL=redis://localhost:6379

# JWT 密钥（请用 openssl rand -hex 32 生成替换）
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Admin JWT 密钥（独立于用户 JWT，请单独生成）
ADMIN_JWT_SECRET=change-me-use-openssl-rand-hex-32

# AES-256 加密密钥（必须恰好 32 字节，用于加密存储 LLM API Key）
ADMIN_ENCRYPTION_KEY=change-me-exactly-32-bytes-long!

# DeepSeek API（如不使用可留空，推荐通过 Admin 面板动态配置 LLM Provider）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API（如不使用可留空）
OPENAI_API_KEY=

# 前端地址（本地 Vite 默认 5200）
FRONTEND_URL=http://localhost:5200

# Docker Compose 请改用 `backend/.env.docker`
# 建议：cp backend/.env.docker.example backend/.env.docker
# 注意：容器内数据库和 Redis host 必须使用服务名 `postgres` / `redis`，不能写 localhost

# Debug：是否将每次 AI 请求的完整 Prompt 与响应记录到本地文件（logs/ai_prompts/）
# 设为 true 开启，留空或删除则关闭（默认关闭）
AI_PROMPT_LOG=
