# ============================
# 缘聚 后端环境变量配置
# ============================
# 使用方式：cp .env.example .env && nano .env

# 服务端口（Docker 容器内部端口，保持 8080 与 Dockerfile 一致）
PORT=8080

# 数据库连接（Docker 部署时 host 应为 postgres 服务名，非 localhost）
# 请将密码替换为你自己的强密码，并保持与 docker-compose.yml 中 DB_PASSWORD 一致
DATABASE_URL=postgres://yuanju:your-strong-password@postgres:5432/yuanju?sslmode=disable

# 数据库密码（供 docker-compose 的 Postgres 容器读取）
DB_PASSWORD=your-strong-password

# Redis
REDIS_URL=redis://redis:6379

# JWT 密钥（请用 openssl rand -hex 32 生成替换）
JWT_SECRET=change-me-use-openssl-rand-hex-32

# Admin JWT 密钥（独立于用户 JWT，请单独生成）
ADMIN_JWT_SECRET=change-me-use-openssl-rand-hex-32

# AES-256 加密密钥（必须恰好 32 字节，用于加密存储 LLM API Key）
ADMIN_ENCRYPTION_KEY=change-me-exactly-32-bytes-long!

# DeepSeek API（如不使用可留空，推荐通过 Admin 面板动态配置 LLM Provider）
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API（如不使用可留空）
OPENAI_API_KEY=

# 前端地址（用于 CORS 配置，Docker 部署时改为你的域名或 IP）
FRONTEND_URL=http://localhost:3000
