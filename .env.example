# 缘聚命理平台 - 环境变量配置模板
# 复制此文件为 .env 并填入真实值

# 服务端口
PORT=8080

# 数据库连接
DATABASE_URL=postgres://yuanju:yuanju123@localhost:5432/yuanju?sslmode=disable

# Redis 连接
REDIS_URL=redis://localhost:6379

# JWT 密钥（生产环境请使用随机长字符串）
JWT_SECRET=yuanju-secret-key-change-in-production

# DeepSeek API（主力 AI 服务）
DEEPSEEK_API_KEY=your-deepseek-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# OpenAI API（备选，DeepSeek 故障时启用）
OPENAI_API_KEY=your-openai-api-key-here

# 前端地址（CORS 白名单）
FRONTEND_URL=http://localhost:5173
